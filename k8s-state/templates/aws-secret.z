apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: names-secret
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: aws-secretsmanager
    kind: ClusterSecretStore
  target:
    name: names-secret
  data:
    - secretKey: FNAME
      remoteRef:
        key: prod/names
        property: FNAME
